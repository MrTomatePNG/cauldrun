# --- AMBIENTE ---
NODE_ENV=development

# --- BANCO DE DATOS ---
DB_USER=buero
DB_PASSWORD=buero_secret
DB_NAME=buero_db
DATABASE_URL="postgresql://buero:buero_secret@db:5432/buero_db"

# --- CACHE E FILAS ---
REDIS_URL="redis://redis:6379"
REDIS_PASSWD=buero_redis_secret

# --- ARMAZENAMENTO ---
S3_ACCESS_KEY=buero_access
S3_SECRET_KEY=buero_secret_key
S3_BUCKET_NAME=buero-media
S3_REGION=us-east-1
S3_ENDPOINT="http://minio:9000"
S3_CDN_URL="http://localhost:9000"

# --- AUTENTICAÇÃO (Mudar para 8080 por causa do Caddy) ---
BETTER_AUTH_SECRET=dev_better_auth_secret
BETTER_AUTH_BASE_URL="http://localhost:8080"

# --- EMAIL ---
RESEND_API_KEY=re_dev_key

# --- CONFIGURAÇÕES DO APP (Muito importante para evitar 403) ---
# Se acessar via Caddy no 8080, o ORIGIN deve ser 8080.
ORIGIN="http://localhost:8080"
GITHUB_REPOSITORY="MrTomatePNG/buero"
