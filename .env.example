# --- Buero Environment Variables ---

# Node environment
NODE_ENV=development

# --- Database (Postgres) ---
# Usado pelo Docker Compose e Prisma
DB_USER=buero
DB_PASSWORD=buero_secret
DB_NAME=buero_db
DATABASE_URL="postgresql://buero:buero_secret@localhost:5432/buero_db"

# --- Redis ---
# Usado pelo BullMQ
REDIS_URL="redis://localhost:6379"
REDIS_PASSWD=buero_redis_secret

# --- S3 (MinIO) ---
S3_ACCESS_KEY=buero_access
S3_SECRET_KEY=buero_secret_key
S3_BUCKET_NAME=buero-media
S3_REGION=us-east-1

# Local S3 (MinIO)
# Se o app roda FORA do docker, use localhost. Se dentro, use minio.
S3_ENDPOINT="http://localhost:9000"

# --- CDN (Varnish) ---
# URL pública para exibição no frontend (mapeada no /etc/hosts)
S3_CDN_URL="https://media.buero.fun"

# --- Better Auth ---
# Gerar com: openssl rand -base64 32
BETTER_AUTH_SECRET=YOUR_BETTER_AUTH_SECRET
BETTER_AUTH_BASE_URL="http://localhost:5173"

# --- Email (Resend) ---
# Em desenvolvimento, o app enviará para o Mailpit (localhost:1025) ignorando esta chave
RESEND_API_KEY=re_123456789

# --- Origin ---
ORIGIN="http://localhost:5173"
