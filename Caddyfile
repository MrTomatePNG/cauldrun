{
	order cache before rewrite

	servers {
		metrics
	}

	cache {
		ttl 6h
		allowed_http_verbs GET HEAD
		simplefs {
			configuration {
				path /var/cache/caddy/media
				directory_size 2GB
			}
		}
	}
}

media.sewercomedy.fun {
	# CORS Headers - Crucial para Range Requests e Cross-Origin
	header {
		Access-Control-Allow-Origin "https://sewercomedy.fun"
		Access-Control-Allow-Methods "GET, OPTIONS"
		Access-Control-Allow-Headers "Range, Content-Type, X-Requested-With"
		Access-Control-Expose-Headers "Content-Range, Content-Length, Accept-Ranges"
		Access-Control-Allow-Credentials "true"
	}

	@options method OPTIONS
	respond @options 204

	@pending path /uploads/pending/*
	respond @pending 403

	cache

	reverse_proxy https://sewer-comedy-s3.br-se1.magaluobjects.com {
		transport http {
			tls
			tls_insecure_skip_verify
		}
		header_up Host sewer-comedy-s3.br-se1.magaluobjects.com
		header_up Accept-Encoding identity
		header_down -Set-Cookie
		header_down -Cache-Control
		header_down +Cache-Control "public, max-age=31536000, immutable"
	}
}

cauldrun.fun, www.cauldrun.fun {
	redir https://sewercomedy.fun{uri} permanent
}

sewercomedy.fun {
	reverse_proxy localhost:3000
}
