{
	order cache before rewrite

	servers {
		metrics
	}

	cache {
		ttl 6h
		allowed_http_verbs GET HEAD
		simplefs {
			configuration {
				path /var/cache/caddy/media
				directory_size 2GB
			}
		}
	}
}

media.sewercomedy.fun {
	log {
		output file /var/log/caddy/media.log
		format json
	}

	# CORS Headers - Crucial para Range Requests e Cross-Origin
	header {
		Access-Control-Allow-Origin "https://sewercomedy.fun"
		Access-Control-Allow-Methods "GET, OPTIONS"
		Access-Control-Allow-Headers "Range, Content-Type, X-Requested-With"
		Access-Control-Expose-Headers "Content-Range, Content-Length, Accept-Ranges"
		Access-Control-Allow-Credentials "true"
	}

	@options method OPTIONS
	respond @options 204

	@pending path /uploads/pending/*
	respond @pending 403

	cache

	reverse_proxy minio:9000
}

cauldrun.fun, www.cauldrun.fun {
	redir https://sewercomedy.fun{uri} permanent
}

sewercomedy.fun {
	log {
		output file /var/log/caddy/access.log
		format json
	}

	reverse_proxy app:3000
}
