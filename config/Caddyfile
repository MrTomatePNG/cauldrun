{
	# Configurações globais
	servers {
		metrics
	}
	# Admin API necessária para o healthcheck e reloads
	admin localhost:2019
}

# --- DESENVOLVIMENTO LOCAL ---
http://localhost:8080 {
	log {
		output stdout
		format json
	}

	# Proxy para o Vite/SvelteKit no container app-dev
	reverse_proxy app-dev:5173 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
	}
}

# --- CDN / Mídia via Varnish (PROD/DEV) ---
http://media.buero.fun, http://localhost:9000 {
	log {
		output stdout
		format json
	}

	header {
		Access-Control-Allow-Origin "*"
		Access-Control-Allow-Methods "GET, OPTIONS"
		Access-Control-Allow-Headers "Range, Content-Type, X-Requested-With"
		Access-Control-Expose-Headers "Content-Range, Content-Length, Accept-Ranges"
		Access-Control-Allow-Credentials "true"
	}

	@options method OPTIONS
	respond @options 204

	reverse_proxy varnish:80 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
	}
}

# --- PRODUÇÃO ---
buero.fun, www.buero.fun {
	log {
		output stdout
		format json
	}

	encode zstd gzip

	reverse_proxy app:3000 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}
}
